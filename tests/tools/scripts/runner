#!/usr/bin/env bash
#
# Thin wrapper for the Go runner.
# Usage: ./scripts/runner <subcommand> [args...]
#
# Subcommands:
#   step-end      Record and verify a step in one call
#   record-step   Record a step result
#   verify-step   Verify a previously recorded step
#   --lane ...    Run the benchmark loop (existing behavior)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOLS_DIR="${SCRIPT_DIR}/.."

exec go run "${TOOLS_DIR}/runner" "$@"
